# Valores por defecto de URLs: editá app_config.py (_DEFAULT_*)
#
# Vertex AI (obligatorio para el LLM)
GOOGLE_CLOUD_PROJECT=tu-proyecto-id
GOOGLE_CLOUD_LOCATION=us-central1
# Autenticación: gcloud auth application-default login
#   o GOOGLE_APPLICATION_CREDENTIALS=/ruta/cuenta-servicio.json
# La cuenta de servicio necesita rol Vertex AI User (roles/aiplatform.user).
# Si Slides/Drive usan otro JSON (GOOGLE_CREDENTIALS_PATH), podés fijar solo Vertex:
# GEMINI_VERTEX_CREDENTIALS_PATH=./vertex-sa.json

# Modelo (si falla 404, probá otro listado en la consola de Vertex para tu región)
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_MODEL=gemini-2.5-flash-lite

# RPM máximo a respetar (si no se define, se infiere: Flash~12, Pro~1.5, Gemma~55)
# GEMINI_RPM_LIMIT=12

# Slides por llamada batch (más = menos llamadas; típico 8–10 con Flash)
# GEMINI_BATCH_CHUNK=9

# Límites de texto (menos tokens = más rápido)
# GEMINI_INTERPRET_CHARS=10000
# GEMINI_STRUCTURE_CHARS=8000
# GEMINI_SEGMENT_CHARS=12000

# GOOGLE_CREDENTIALS_PATH=./credentials.json
