# Valores por defecto de URLs y Gemini: editá app_config.py (_DEFAULT_*)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Modelo (si falla 404, probá otro desde AI Studio → List models)
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_MODEL=gemini-2.5-flash-lite

# RPM máximo a respetar (si no se define, se infiere: Flash~12, Pro~1.5, Gemma~55)
# GEMINI_RPM_LIMIT=12

# Slides por llamada batch (más = menos llamadas; típico 8–10 con Flash)
# GEMINI_BATCH_CHUNK=9

# Límites de texto (menos tokens = más rápido)
# GEMINI_INTERPRET_CHARS=10000
# GEMINI_STRUCTURE_CHARS=8000
# GEMINI_SEGMENT_CHARS=12000

# GOOGLE_CREDENTIALS_PATH=./credentials.json
