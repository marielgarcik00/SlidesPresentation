# API key de Gemini (obtenela en https://aistudio.google.com/apikey)
GEMINI_API_KEY=tu_api_key

# Opcional: modelo (por defecto gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Por defecto true: todas las slides se rellenan en 1–2 llamadas batch (no 1 por slide). Desactivar: GEMINI_BATCH_SLIDES=false
# GEMINI_BATCH_SLIDES=true

# Si batch está desactivado: pausa entre cada llamada (por defecto 20).
# GEMINI_DELAY_BETWEEN_CALLS=20

# Opcional: ruta al JSON de credenciales de la cuenta de servicio de Google
# GOOGLE_CREDENTIALS_PATH=./credentials.json
